#!/bin/sh
set -eu
[ "$#" -eq 1 ] && [ -f "$1" ] || { echo 'usage: vmexport FILE' >&2; exit 2; }
size=$(wc -c < "$1")
[ "$size" -le 8388608 ] || { echo 'vmexport: files are limited to 8 MiB' >&2; exit 1; }
b64() { printf %s "$1" | base64 | tr -d '\n'; }
id="$$-$(date +%s)"
printf '__V86RPC__\tEXPORT\t%s\t%s\t' "$id" "$(b64 "$(basename "$1")")"
base64 < "$1" | tr -d '\n'
printf '\n'
