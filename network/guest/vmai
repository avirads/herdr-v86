#!/bin/sh
set -eu
case "${1:-}" in -h|--help) echo 'usage: OPENAI_API_KEY=... vmai PROMPT...'; echo 'Calls an OpenAI-compatible /responses endpoint through browser fetch; CORS applies.'; exit 0;; esac
[ "$#" -ge 1 ] || { echo 'usage: OPENAI_API_KEY=... vmai PROMPT...' >&2; exit 2; }
[ -n "${OPENAI_API_KEY:-}" ] || { echo 'vmai: set OPENAI_API_KEY' >&2; exit 2; }
prompt=$(printf '%s ' "$@" | sed 's/["\\]/\\&/g')
body="{\"model\":\"${OPENAI_MODEL:-gpt-4.1-mini}\",\"input\":\"$prompt\"}"
exec vmfetch -X POST \
  -H "Authorization: Bearer $OPENAI_API_KEY" \
  -H 'Content-Type: application/json' \
  -d "$body" -o - "${OPENAI_BASE_URL:-https://api.openai.com/v1}/responses"
