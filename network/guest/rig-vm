#!/bin/sh
set -eu
op=RIG
if [ "${1:-}" = "--codeact" ]; then op=CODEACT; shift; fi
[ "$#" -gt 0 ] || { echo 'usage: rig [--codeact] TASK...' >&2; exit 2; }
b64() { printf %s "$1" | base64 | tr -d '\n'; }
printf '__V86RPC__\tAGENT_%s\t%s\t%s\n' "$op" "$$-$(date +%s)" "$(b64 "$*")" > /dev/ttyS0
echo '[rig] submitted to the ready browser agent.'
