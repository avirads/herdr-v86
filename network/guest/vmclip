#!/bin/sh
set -eu
b64() { printf %s "$1" | base64 | tr -d '\n'; }
id="$$-$(date +%s)"
case "${1:-read}" in
  read)
    stty -echo; trap 'stty echo' EXIT INT TERM
    printf '__V86RPC__\tCLIPBOARD_READ\t%s\n' "$id"
    while IFS="$(printf '\t')" read -r prefix response_id kind value; do
      [ "$prefix:$response_id" = "__V86RPC_RESPONSE__:$id" ] || continue
      [ "$kind" = DATA ] && printf %s "$value" | base64 -d
      [ "$kind" = END ] && break
      if [ "$kind" = ERROR ]; then printf %s "$value" | base64 -d >&2; exit 1; fi
    done
    stty echo; trap - EXIT INT TERM ;;
  write)
    value=$(cat); printf '__V86RPC__\tCLIPBOARD_WRITE\t%s\t%s\n' "$id" "$(b64 "$value")" ;;
  *) echo 'usage: vmclip [read|write]' >&2; exit 2 ;;
esac
